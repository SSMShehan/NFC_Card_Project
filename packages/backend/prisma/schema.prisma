// ============================================================
//  TAGIT — Prisma Schema
//  Database: PostgreSQL (Supabase)
//  ORM:      Prisma 5
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
//  ENUMS
// ============================================================

enum SubscriptionTier {
  FREE
  PREMIUM
  CORPORATE
}

enum ProfileStatus {
  ACTIVE
  SUSPENDED
  STEALTH
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LinkPlatform {
  CUSTOM
  LINKEDIN
  GITHUB
  TWITTER
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  TIKTOK
  WHATSAPP
  TELEGRAM
  WEBSITE
  PORTFOLIO
  BEHANCE
  DRIBBBLE
  MEDIUM
  SUBSTACK
  CALENDLY
  EMAIL
  PHONE
}

// ============================================================
//  MODELS
// ============================================================

/// Core authentication entity. One-to-one with Profile.
model User {
  id               String           @id @default(cuid())
  email            String           @unique
  passwordHash     String
  subscriptionTier SubscriptionTier @default(FREE)

  // Relations
  profile Profile?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// Public-facing profile data tied to a single User.
/// Contains all information displayed on the NFC tap landing page.
model Profile {
  id             String        @id @default(cuid())
  username       String        @unique
  displayName    String  
  bio            String? 
  phone          String? 
  email          String? 
  company        String? 
  jobTitle       String? 
  website        String? 
  profilePicture String? // URL to hosted image
  companyLogo    String? // URL to hosted company logo
  status         ProfileStatus @default(ACTIVE)

  /// Total number of times the NFC card has been tapped (profile viewed)
  tapCount Int @default(0)

  // Ownership — 1:1 with User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations
  links                Link[]
  verificationRequests VerificationRequest[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

/// Social or portfolio link associated with a profile.
/// isActive controls real-time visibility without deleting the record.
model Link {
  id        String       @id @default(cuid())
  platform  LinkPlatform @default(CUSTOM)
  url       String  
  label     String  
  iconType  String? // Optional override for custom icon key
  sortOrder Int     @default(0) // Controls display order
  isActive  Boolean @default(true) // Toggled instantly via mobile app

  // Ownership — many:1 with Profile
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("links")
}

/// Audit log for changes to sensitive profile fields (displayName, profilePicture, companyLogo).
/// These fields bypass direct DB writes and instead create a VerificationRequest
/// that must be approved (by AI or manually) before going live.
model VerificationRequest {
  id             String             @id @default(cuid())
  fieldName      String             // e.g. "displayName", "profilePicture"
  newValue       String             // The proposed new value (URL or text)
  status         VerificationStatus @default(PENDING)
  moderationNote String? // AI confidence score or reviewer note

  // Ownership — many:1 with Profile
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Timestamps
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime? // Set when status moves from PENDING to APPROVED/REJECTED

  @@map("verification_requests")
}
