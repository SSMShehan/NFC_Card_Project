# ============================================================
#  NEXUS Backend — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the .env file to version control.
# ============================================================

# --------------------------
# Server Configuration
# --------------------------
NODE_ENV=development
PORT=4000

# --------------------------
# Supabase / PostgreSQL
# --------------------------
# Connection string from Supabase: Settings > Database > Connection string (URI mode)
# Use the "Transaction" pooler URL for serverless environments,
# or the "Session" pooler URL for long-lived connections.
DATABASE_URL="postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (for Prisma migrations — NOT the pooled URL)
DIRECT_URL="postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres"

# --------------------------
# JWT & OAuth Authentication
# --------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-replace-this-immediately"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Google OAuth Client ID (must match the frontend NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID="543254844488-38h35hddtfnmajai6mnr8hatu3cnniva.apps.googleusercontent.com"

# --------------------------
# CORS
# --------------------------
# Comma-separated allowed origins
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# --------------------------
# File Upload
# --------------------------
# Max file size in bytes (default: 5MB)
MAX_FILE_SIZE_BYTES=5242880
# Local upload directory (for dev only; use S3/Supabase Storage in production)
UPLOAD_DIR="uploads"

# --------------------------
# AWS Rekognition (AI Image Moderation)
# --------------------------
# Leave blank to use the built-in mockup pipeline during development.
# Fill in real credentials to enable live moderation.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_REKOGNITION_MIN_CONFIDENCE=75

# --------------------------
# Supabase Storage (Production Image Hosting)
# --------------------------
SUPABASE_URL="https://[YOUR-SUPABASE-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="nexus-profile-images"

# --------------------------
# Rate Limiting
# --------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
