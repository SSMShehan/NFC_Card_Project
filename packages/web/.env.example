# ============================================================
#  NEXUS Web — Environment Variables
#  Copy this file to .env.local and fill in your values.
# ============================================================

# The URL of the NEXUS backend API
# In production, replace with your deployed backend URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# The public base URL of this Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Live Google OAuth Client ID ──
# 1. Create a Web application client ID at https://console.cloud.google.com/apis/credentials
# 2. Add http://localhost:3000 to "Authorized JavaScript origins"
# 3. Paste the generated client ID below:
NEXT_PUBLIC_GOOGLE_CLIENT_ID=543254844488-38h35hddtfnmajai6mnr8hatu3cnniva.apps.googleusercontent.com

# ── Live Apple Service ID ──
NEXT_PUBLIC_APPLE_CLIENT_ID=cards.tagit.web
